# RevenueCat (get from https://app.revenuecat.com)
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_YOUR_KEY_HERE

# OpenRouter (get from https://openrouter.ai/keys)
EXPO_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# OVH Whisper STT (optional, for voice features)
EXPO_PUBLIC_OVH_WHISPER_TOKEN=YOUR_TOKEN_HERE
